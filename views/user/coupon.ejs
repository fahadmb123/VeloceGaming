<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Coupons | Veloce Gaming</title>
    <link rel="stylesheet" href="style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>

<body>
    <!-- Header -->
    <header>
        <div class="header-container">
            <div class="logo">
                <div class="logo-icon"><i class="fa-solid fa-check"></i></div>
                <div class="logo-text">
                    <span class="brand">VELOCE</span>
                    <span class="sub-brand">GAMING</span>
                </div>
            </div>
            <nav>
                <a href="../home/index.html">Home</a>
                <a href="../shop/index.html">Shop</a>
            </nav>
            <div class="header-icons">
                <a href="../wishlist/index.html"><i class="fa-regular fa-heart"></i></a>
                <a href="../cart/index.html" class="cart-icon-wrapper">
                    <i class="fa-solid fa-cart-shopping"></i>
                    <span class="cart-badge">3</span>
                </a>
                <div class="user-menu">
                    <div class="profile-circle">
                        <i class="fa-solid fa-user"></i>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <main class="container">
        <!-- Sidebar -->
        <aside class="profile-sidebar">
            <div class="profile-header">
                <div class="user-avatar"></div>
                <h2 class="user-name">John Doe</h2>
            </div>
            <ul class="profile-nav">
                <li><a href="#"><i class="fa-regular fa-user"></i> My Profile</a></li>
                <li><a href="../myOrders/index.html"><i class="fa-solid fa-box-open"></i> My Orders</a></li>
                <li><a href="../wishlist/index.html"><i class="fa-regular fa-heart"></i> My Wishlist</a></li>
                <li class="active"><a href="#"><i class="fa-solid fa-gift"></i> Coupon</a></li>
                <li><a href="../wallet/index.html"><i class="fa-solid fa-wallet"></i> Wallet</a></li>
            </ul>
            <button class="logout-btn">
                <i class="fa-solid fa-arrow-right-from-bracket"></i> Logout
            </button>
        </aside>

        <!-- Main Content -->
        <div class="profile-content">
            <h1 class="page-title">Coupons</h1>

            <div class="coupon-grid">
                <!-- Coupon Card 1 -->
                <div class="coupon-card">
                    <div class="coupon-top">
                        <div class="discount-badge">20% OFF</div>
                        <div class="min-purchase">Min.Purchase 1500 ₹</div>
                    </div>
                    <div class="coupon-bottom">
                        <div class="coupon-label">COUPON CODE</div>
                        <div class="code-container">
                            <span class="code-text">WELCOME32</span>
                        </div>
                        <div class="max-discount">Max. Discount 400 ₹</div>
                        <div class="expiry-date">Exp: 30-Jul-2026</div>
                        <button class="copy-btn">Copy Code <i class="fa-solid fa-link"></i></button>
                    </div>
                </div>

                <!-- Coupon Card 2 -->
                <div class="coupon-card">
                    <div class="coupon-top">
                        <div class="discount-badge">20% OFF</div>
                        <div class="min-purchase">Min.Purchase 1500 ₹</div>
                    </div>
                    <div class="coupon-bottom">
                        <div class="coupon-label">COUPON CODE</div>
                        <div class="code-container">
                            <span class="code-text">WELCOME32</span>
                        </div>
                        <div class="max-discount">Max. Discount 400 ₹</div>
                        <div class="expiry-date">Exp: 30-Jul-2026</div>
                        <button class="copy-btn">Copy Code <i class="fa-solid fa-link"></i></button>
                    </div>
                </div>

                <!-- Coupon Card 3 -->
                <div class="coupon-card">
                    <div class="coupon-top">
                        <div class="discount-badge">20% OFF</div>
                        <div class="min-purchase">Min.Purchase 1500 ₹</div>
                    </div>
                    <div class="coupon-bottom">
                        <div class="coupon-label">COUPON CODE</div>
                        <div class="code-container">
                            <span class="code-text">WELCOME32</span>
                        </div>
                        <div class="max-discount">Max. Discount 400 ₹</div>
                        <div class="expiry-date">Exp: 30-Jul-2026</div>
                        <button class="copy-btn">Copy Code <i class="fa-solid fa-link"></i></button>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <script>
        document.querySelectorAll('.copy-btn').forEach(button => {
            button.addEventListener('click', () => {
                const codeText = button.parentElement.querySelector('.code-text').textContent;
                navigator.clipboard.writeText(codeText).then(() => {
                    const originalText = button.innerHTML;
                    button.innerHTML = 'Copied! <i class="fa-solid fa-check"></i>';
                    button.classList.add('copied');
                    setTimeout(() => {
                        button.innerHTML = originalText;
                        button.classList.remove('copied');
                    }, 2000);
                });
            });
        });
    </script>
</body>

</html>
