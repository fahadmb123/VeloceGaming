<link rel="stylesheet" href="/css/user/profile.css">


<!-- Header -->
<header>
    <div class="header-container">
        <div class="logo">
            <div class="logo-icon"><i class="fa-solid fa-check"></i></div>
            <div class="logo-text">
                <span class="brand">VELOCE</span>
                <span class="sub-brand">GAMING</span>
            </div>
        </div>
        
        <nav>
            <a href="/">Home</a>
            <a href="/shop">Shop</a>
        </nav>

        <div class="header-icons">
            <a href="/wishlist"><i class="fa-regular fa-heart"></i></a>
            <a href="/cart"><i class="fa-solid fa-cart-shopping"></i></a>
            <div class="profile-circle-small">
                <% if (user.profileImage){ %>
                        <img src="<%= user.profileImage %>" 
                           style="width:100%; height:100%; object-fit:cover; border-radius:50%;">
                    <% }  else { %>
                    <%= user.name.charAt(0).toUpperCase() %> 
                    <% } %> 
            </div>
        </div>
    </div>
</header>

<main class="profile-container">
    <!-- Sidebar -->
    <aside class="sidebar">
        <div class="user-avatar-section">

            <div class="user-avatar-container">
                <div class="user-avatar" id="profileAvatarDisplay">
                    <% if (user.profileImage){ %>
                        <img src="<%= user.profileImage %>" 
                           style="width:100%; height:100%; object-fit:cover; border-radius:50%;">
                    <% }  else { %>
                    <%= user.name.charAt(0).toUpperCase() %> 
                    <% } %> 
                    <!-- <%= user.name.charAt(0).toUpperCase() %> -->
                </div>
                <button class="btn-avatar-edit" id="openUploadModal">
                    <i class="fa-solid fa-camera"></i>
                </button>
                <!-- <% if (user.profileImage) { %> -->
                <button  class="btn-avatar-remove" id="removeProfilePhoto" title="Remove Photo">
                    <i class="fa-solid fa-trash"></i>
                </button>
                <!-- <% } %> -->
            </div>
            <h3><%= user.name.toUpperCase() %></h3>
        </div>

        <ul class="sidebar-menu">
            <li class="active"><a href="#"><i class="fa-solid fa-briefcase"></i> My Profile</a></li>
            <li><a href="/orderHistory"><i class="fa-solid fa-clipboard-list"></i> My Orders</a></li>
            <li><a href="/wishlist"><i class="fa-regular fa-heart"></i> My Wishlist</a></li>
            <li><a href="#"><i class="fa-solid fa-ticket"></i> Coupon</a></li>
            <li><a href="#"><i class="fa-solid fa-wallet"></i> Wallet</a></li>
        </ul>

        <a style="text-decoration: none;" href="/logout">
            <button class="btn-logout">
                <i class="fa-solid fa-right-from-bracket"></i> Logout
            </button>
        </a>
    </aside>

    <!-- Main Content -->
    <section class="profile-content">
        <h2>Edit Profile</h2>

        <form class="edit-profile-form" action="/profile" method="post" id="registerForm">
            <div  class="form-section">
                <div id="nameDiv" class="form-group">
                    <label>Name</label>
                    <input id="name" name="name" type="text" value="<%= user.name %>">
                    <p style="color: red;font-size: 13px;font-weight: normal;margin-top: 2px !important;display: none;">Name Requierd At Lease 3 letters</p>
                </div>
                <div id="emailDiv" class="form-group">
                    <label>Email</label>
                    <input id="email" name="email" type="email" value="<%= user.email %>">
                    <p style="color: red;font-size: 13px;font-weight: normal;margin-top: 2px !important;display: none;">Email Requierd</p>
                </div>
            </div>

            <div class="password-change-section">
                <h3>Password Change</h3>
                <div id="currentPasswordDiv" class="form-group">
                    <label>Current Password</label>
                    <div class="input-wrapper">
                        <input name="currentPassword" minlength="6" type="password" id="currentPassword" placeholder="••••••••">
                        <span class="toggle-password" onclick="togglePassword('currentPassword', this)">Show</span>
                    </div>
                    <p style="color: red;font-size: 13px;font-weight: normal;margin-top: 2px !important;display: none;">Current Requierd</p>
                </div>
                <div id="newPasswordDiv" class="form-group">
                    <label>New Password</label>
                    <div class="input-wrapper">
                        <input name="newPassword" minlength="6" type="password" id="newPassword" placeholder="••••••••">
                        <span class="toggle-password" onclick="togglePassword('newPassword', this)">Show</span>
                    </div>
                    <p style="color: red;font-size: 13px;font-weight: normal;margin-top: 2px !important;display: none;">New Password Requierd</p>
                </div>
                <div id="confirmPasswordDiv" class="form-group">
                    <label>Confirm New Password</label>
                    <div class="input-wrapper">
                        <input name="confirmPassword" minlength="6" type="password" id="confirmPassword" placeholder="••••••••">
                        <span class="toggle-password" onclick="togglePassword('confirmPassword', this)">Show</span>
                    </div>
                    <p style="color: red;font-size: 13px;font-weight: normal;margin-top: 2px !important;display: none;">Confirm Password Requierd</p>
                </div>
                
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-save">Save Changes</button>
            </div>
        </form>

        <div class="referral-section">
            <h3>REFERRAL CODE</h3>
            <div class="referral-box">
                <span id="referralText" class="referral-code"><%= user.refferalCode %></span>
                <button onclick="copyCode()" class="btn-copy">Copy Code</button>
            </div>
        </div>

        <div class="address-section">
            <a href="/address"><button class="btn-show-address">Show Saved Address</button></a>
        </div>
    </section>
    <% if (typeof swalMessage !== "undefined" && swalMessage) { %>
    <span id="swalMessage" style="display:none;">
        <%= swalMessage %>
    </span>
    <% } %>
</main>

<div class="mobile-bottom-nav">
        <a href="/" class="nav-item">
            <i class="fa-solid fa-house"></i>
            <span>Home</span>
        </a>
        <a href="#" class="nav-item">
            <i class="fa-solid fa-bag-shopping"></i>
            <span>Shop</span>
        </a>
        <a href="#" class="nav-item">
            <i class="fa-solid fa-cart-shopping"></i>
            <span>Cart</span>
        </a>
        <a href="#" class="nav-item">
            <i class="fa-solid fa-heart"></i>
            <span>Wishlist</span>
        </a>
        <a href="/profile" class="nav-item active">
            <i class="fa-solid fa-user"></i>
            <span>Profile</span>
        </a>
    </div>





    <div class="upload-modal" id="uploadModal">
        <div class="modal-overlay" id="modalOverlay"></div>
        <div class="modal-content">
            <div class="modal-header">
                <h3>Update Profile Photo</h3>
                <button class="btn-close-modal" id="closeUploadModal">
                    <i class="fa-solid fa-xmark"></i>
                </button>
            </div>
            <div class="modal-body">
                <div class="upload-area" id="dropZone">
                    <div class="upload-icon">
                        <i class="fa-solid fa-cloud-arrow-up"></i>
                    </div>
                    <p>Drag and drop your image here Maximum 2 MB</p>
                    <span>or</span>
                    <button class="btn-choose-file" onclick="document.getElementById('fileInput').click()">Browse
                        Files</button>
                    <input  type="file" id="fileInput" accept="image/*" hidden>
                </div>
                <div class="image-preview-container" id="previewContainer">
                    <img id="imagePreview" src="" alt="Preview">
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn-modal-cancel" id="cancelUpload">Cancel</button>
                <button class="btn-modal-upload" id="confirmUpload" disabled>Apply Changes</button>
            </div>
        </div>
    </div>
    <div id="toast" class="toast">
       <span id="toast-message"></span>
    </div>


<script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.13/cropper.min.js"></script>
<script src="/js/user/profile.js"></script>