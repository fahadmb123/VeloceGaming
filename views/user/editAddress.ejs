            }
        }*/
       if (phone) {
            if (!/^[0-9]{10}$/.test(phone)) {
                swal("Invalid Phone Number");
                return false;
            }
        }

        event.target.submit()
        return true
    }


    window.addEventListener("pageshow", function (event) {
        if (event.persisted) {
            window.location.reload();
