<link rel="stylesheet" href="/css/user/checkout.css">

<!-- Header -->
<header>
<div id="admin-spinner" class="spinner-overlay" style="display:none;">
    <div class="spinner"></div>
</div>
<%
    cart = typeof cart !== "undefined" ? cart : null
    variant = typeof variant !== "undefined" ? variant : null
%>

    <div class="header-container">
        <div class="logo">
            <div class="logo-icon"><i class="fa-solid fa-check"></i></div>
            <div class="logo-text">
                <span class="brand">VELOCE</span>
                <span class="sub-brand">GAMING</span>
            </div>
        </div>

        <nav>
            <a href="/">Home</a>
            <a href="/shop">Shop</a>
        </nav>

        <div class="search-bar">
            <input type="text" placeholder="What are you looking for?">
            <i class="fa-solid fa-magnifying-glass"></i>
        </div>

        <div class="header-icons">
            <a href="/wishlist"><i class="fa-regular fa-heart"></i></a>
            <a href="/cart" class="cart-icon-wrapper">
                <i class="fa-solid fa-cart-shopping"></i>
                <% if (Number(cartCount) > 0) { %>
                    <span class="cart-badge"><%= cartCount %></span>
                <% } %>
            </a>
            <div class="user-menu">
                <a style="text-decoration: none;" href="/profile">
                <div class="profile-circle">
                    <% if (user.profileImage){ %>
                        <img src="<%= user.profileImage %>"  style="width:100%; height:100%; object-fit:cover; border-radius:50%;">
                    <% }  else { %>
                    <%= user.name.charAt(0).toUpperCase() %> 
                    <% } %> 
                </div>
                </a>
            </div>
        </div>
    </div>
</header>

<main class="checkout-main">
    <h1 class="page-title">Checkout</h1>

    <div class="checkout-layout">
        <div class="checkout-content">
            <!-- Delivery Address -->
            <section class="checkout-section">
                <h2 class="section-title">Delivery Address</h2>
                <div class="address-list">
                    <% if (address) { %>
                    <% address.forEach ((obj,index) => { %>
                    <label class="address-card selected">
                        <input value="<%= obj._id %>" class="addressOption" type="radio" name="address" <%= index === 0 ? "checked" : "" %>>
                        <div class="radio-custom"></div>
                        <div class="address-details">
                            <h3><%= obj.fullName %></h3>
                            <p><%= obj.address %>  ,  <%= obj.state %>  ,  <%= obj.city %>  --  <%= obj.pincode %> -------- , Address Type  : <%= obj.type %></p>
                        </div>
                        <button onclick="editAddress('<%= obj._id %>', '<%= variant ? variant._id : null %>')" class="btn-edit-small" type="button">
                            <i class="fa-solid fa-pen"></i> Edit
                        </button>
                    </label>
                    <% }) %>
                    <% } %>
                </div>
                <button class="btn-add-address" onclick="addAddress('<%= variant ? variant._id : null %>')">+ Add New Address</button>
            </section>

            <!-- Payment Method -->
            <section class="checkout-section">
                <h2 class="section-title">Payment Method</h2>
                <div class="payment-methods">
                    <label class="payment-option">
                        <input value="Wallet" class="paymentOption" type="radio" name="payment" >
                        <div class="radio-custom"></div>
                        <span>Wallet</span>
                    </label>
                    <label class="payment-option">
                        <input value="Razorpay" class="paymentOption" type="radio" name="payment">
                        <div class="radio-custom"></div>
                        <span>Razorpay</span>
                    </label>
                    <label class="payment-option">
                        <input value="cod" class="paymentOption" type="radio" name="payment" checked>
                        <div class="radio-custom"></div>
                        <span>Cash on Delivery</span>
                    </label>
                </div>
            </section>

            <!-- Cart Items -->
            <section class="checkout-section">
                <h2 class="section-title">Items</h2>
                <div class="checkout-items">
                    <% if (cart && cart.items) { %>
                        <% cart.items.forEach ( (item,index) => { %>
                    <div class="checkout-item">
                        <a style="text-decoration: none;" href="/product/<%= item.variantId._id %>">
                            <div class="item-image">
                            <img  src="<%= item.variantId?.images[0] %>"  style="width:100%; height:100%; object-fit:cover; ">
                        </div>
                    </a>
                        <div class="item-info">
                            <h3><%= item.variantId?.productId?.name %></h3>
                            <p>Qty: <%= item.quantity %></p>
                        </div>
                        <div class="item-price">₹ <%= item.variantId?.offeredPrice.toLocaleString("en-IN") %></div>
                    </div>
                    <% }) %>
                    <% } else { %>
                        <% if (variant) { %>
                    <div class="checkout-item">
                        <a style="text-decoration: none;" href="/product/<%= variant._id %>">
                            <div class="item-image">
                                <img  src="<%= variant.images[0] %>"  style="width:100%; height:100%; object-fit:cover;">
                            </div>
                        </a>
                        <div class="item-info">
                            <h3><%= variant.productId?.name %></h3>
                            <p>Qty: <%= quantity %></p>
                        </div>
                        <div class="item-price">₹ <%= variant.offeredPrice.toLocaleString("en-IN") %></div>
                    </div>
                       <% } %>
                    <% } %>
                </div>
            </section>
        </div>
        <!-- Right Column: Order Summary + Available Coupons -->
    <div class="right-column">
        <!-- Order Summary -->
        <aside class="order-summary">
            <h2 class="summary-title">Order Summary</h2>
            <div class="summary-details">
                <div class="summary-row">
                    <span>Subtotal</span>
                    <span>₹ <%= subtotal.toLocaleString("en-IN") %></span>
                </div>
                <div class="summary-row">
                    <span>Shipping</span>
                    <span class="free">
                        <% if (shipping === 0) { %>
                            Free
                        <% } else { %>
                            <%= shipping %>
                        <% } %>
                    </span>
                </div>
                <div class="summary-row">
                    <span>Discount</span>
                    <span>₹<%= (discount ?? 0).toLocaleString("en-IN") %></span>
                </div>

                

                <div class="total-row">
                    <span class="total-amount">₹ <%= total.toLocaleString("en-IN") %></span>
                </div>
            </div>
            <button onclick="placeOrder(`<%= variant ? variant._id : ""  %>`)"  id="placeOrder" class="btn-place-order">Place Order</button>
        </aside>
        <% if (coupon) { %>
            <div class="applied-coupon-box" id="appliedCouponBox">
                <div class="applied-coupon-header">
                    <i class="fa-solid fa-circle-check"></i>
                    <span>Coupon Applied</span>
                </div>
                <div class="applied-coupon-body">
                    <div class="applied-coupon-info">
                        <i class="fa-solid fa-tag"></i>
                        <span id="appliedCouponCode" class="applied-code"><%= coupon.code %></span>
                        <% if (coupon.type === "percentage") { %>
                            <span id="appliedCouponSaving" class="applied-saving"><%= coupon.discountValue %>% off Up To ₹<%= coupon.maxDiscount.toLocaleString("en-IN") %></span>
                        <% } else { %>
                            <span id="appliedCouponSaving" class="applied-saving">₹<%= coupon.discountValue.toLocaleString("en-IN") %> off</span>
                        <% } %>
                    </div>
                    <button class="btn-remove-coupon" onclick="removeCoupon()">
                        <i class="fa-solid fa-xmark"></i> Remove
                    </button>
                </div>
            </div>
        <% } %>
        <!-- Available Coupons -->
            <div class="available-coupons-box">
                <div class="coupons-box-header">
                    <i class="fa-solid fa-tag"></i>
                    <h3>Available Coupons</h3>
                </div>
                <div class="coupons-list">
                    <% if (coupons.length !== 0) { 
                        coupons.forEach((coupon,index)=>{  %>
                    <div class="coupon-card">
                        <div class="coupon-left">
                            <span class="coupon-code-tag"><%= coupon.code %></span>
                            <% if (coupon.type === "percentage") { %>
                                <p class="coupon-desc">Get <%= coupon.discountValue %>% off on orders With Get Up To ₹<%= coupon.maxDiscount.toLocaleString("en-IN") %></p>
                            <% } else { %>
                                <p class="coupon-desc">Get ₹<%= coupon.discountValue.toLocaleString("en-IN") %> off on orders</p>
                            <% } %>
                            <p class="coupon-expiry"><%= coupon.expiryDate.toLocaleDateString("en-GB", {
                                    day: "2-digit",
                                    month: "short",
                                    year: "numeric" 
                                }) %></p>
                        </div>
                        <button class="btn-coupon-apply" onclick="applyCoupon('<%= coupon.code %>')">Apply</button>
                    </div>

                       <% })
                    } else { %>
                        <h2><pre>     No Available Coupons</pre> </h2>
                    <% } %>

                </div>
            </div>
            

        </div><!-- end right-column -->
    </div>
</main>

<!-- Mobile Bottom Navbar -->
<div class="mobile-bottom-nav">
    <a href="../home/index.html" class="nav-item">
        <i class="fa-solid fa-house"></i>
        <span>Home</span>
    </a>
    <a href="../shop/index.html" class="nav-item">
        <i class="fa-solid fa-bag-shopping"></i>
        <span>Shop</span>
    </a>
    <a href="../cart/index.html" class="nav-item">
        <i class="fa-solid fa-cart-shopping"></i>
        <span>Cart</span>
    </a>
    <a href="../wishlist/index.html" class="nav-item">
        <i class="fa-solid fa-heart"></i>
        <span>Wishlist</span>
    </a>
    <a href="../profile/index.html" class="nav-item">
        <i class="fa-solid fa-user"></i>
        <span>Profile</span>
    </a>
</div>
<% if (typeof swalMessage !== "undefined" && swalMessage) { %>
<span id="swalMessage" style="display:none;">
    <%= swalMessage %>
</span>
<% } %>

<script src="https://checkout.razorpay.com/v1/checkout.js"></script>
<script src="/js/user/checkout.js"></script>