<link rel="stylesheet" href="/css/user/checkout.css">

<!-- Header -->
<header>

<%
    cart = typeof cart !== "undefined" ? cart : null
    variant = typeof variant !== "undefined" ? variant : null;
%>

    <div class="header-container">
        <div class="logo">
            <div class="logo-icon"><i class="fa-solid fa-check"></i></div>
            <div class="logo-text">
                <span class="brand">VELOCE</span>
                <span class="sub-brand">GAMING</span>
            </div>
        </div>

        <nav>
            <a href="/">Home</a>
            <a href="/shop">Shop</a>
        </nav>

        <div class="search-bar">
            <input type="text" placeholder="What are you looking for?">
            <i class="fa-solid fa-magnifying-glass"></i>
        </div>

        <div class="header-icons">
            <a href="/wishlist"><i class="fa-regular fa-heart"></i></a>
            <a href="/cart"><i class="fa-solid fa-cart-shopping"></i></a>
            <div class="user-menu">
                <a style="text-decoration: none;" href="/profile">
                <div class="profile-circle">
                    <% if (user.profileImage){ %>
                        <img src="<%= user.profileImage %>"  style="width:100%; height:100%; object-fit:cover; border-radius:50%;">
                    <% }  else { %>
                    <%= user.name.charAt(0).toUpperCase() %> 
                    <% } %> 
                </div>
                </a>
            </div>
        </div>
    </div>
</header>

<main class="checkout-main">
    <h1 class="page-title">Checkout</h1>

    <div class="checkout-layout">
        <div class="checkout-content">
            <!-- Delivery Address -->
            <section class="checkout-section">
                <h2 class="section-title">Delivery Address</h2>
                <div class="address-list">
                    <% if (address) { %>
                    <% address.forEach ((obj,index) => { %>
                    <label class="address-card selected">
                        <input type="radio" name="address" checked>
                        <div class="radio-custom"></div>
                        <div class="address-details">
                            <h3><%= obj.fullName %></h3>
                            <p><%= obj.address %>  ,  <%= obj.state %>  ,  <%= obj.city %>  --  <%= obj.pincode %> -------- , Address Type  : <%= obj.type %></p>
                        </div>
                        <button onclick="editAddress(`<%= obj._id %>`)" class="btn-edit-small" type="button">
                            <i class="fa-solid fa-pen"></i> Edit
                        </button>
                    </label>
                    <% }) %>
                    <% } %>
                </div>
                <button class="btn-add-address">+ Add New Address</button>
            </section>

            <!-- Payment Method -->
            <section class="checkout-section">
                <h2 class="section-title">Payment Method</h2>
                <div class="payment-methods">
                    <label class="payment-option">
                        <input type="radio" name="payment" checked>
                        <div class="radio-custom"></div>
                        <span>Wallet</span>
                    </label>
                    <label class="payment-option">
                        <input type="radio" name="payment">
                        <div class="radio-custom"></div>
                        <span>Razorpay</span>
                    </label>
                    <label class="payment-option">
                        <input type="radio" name="payment">
                        <div class="radio-custom"></div>
                        <span>Cash on Delivery</span>
                    </label>
                </div>
            </section>

            <!-- Cart Items -->
            <section class="checkout-section">
                <h2 class="section-title">Items</h2>
                <div class="checkout-items">
                    <% if (cart && cart.items) { %>
                        <% cart.items.forEach ( (item,index) => { %>
                    <div class="checkout-item">
                        <a style="text-decoration: none;" href="/product/<%= item.variantId._id %>">
                            <div class="item-image">
                            <img  src="<%= item.variantId?.images[0] %>"  style="width:100%; height:100%; object-fit:cover; border-radius:50%;">
                        </div>
                    </a>
                        <div class="item-info">
                            <h3><%= item.variantId?.productId?.name %></h3>
                            <p>Qty: <%= item.quantity %></p>
                        </div>
                        <div class="item-price">₹ <%= item.variantId?.offeredPrice %></div>
                    </div>
                    <% }) %>
                    <% } else { %>
                        <% if (variant) { %>
                    <div class="checkout-item">
                        <a style="text-decoration: none;" href="/product/<%= variant._id %>">
                            <div class="item-image">
                                <img  src="<%= variant.images[0] %>"  style="width:100%; height:100%; object-fit:cover; border-radius:50%;">
                            </div>
                        </a>
                        <div class="item-info">
                            <h3><%= variant.productId?.name %></h3>
                            <p>Qty: <%= quantity %></p>
                        </div>
                        <div class="item-price">₹ <%= variant.offeredPrice %></div>
                    </div>
                       <% } %>
                    <% } %>
                </div>
            </section>
        </div>

        <!-- Order Summary -->
        <aside class="order-summary">
            <h2 class="summary-title">Order Summary</h2>
            <div class="summary-details">
                <div class="summary-row">
                    <span>Subtotal</span>
                    <span>₹ <%= subtotal %></span>
                </div>
                <div class="summary-row">
                    <span>Shipping</span>
                    <span class="free">
                        <% if (shipping === 0) { %>
                            Free
                        <% } else { %>
                            <%= shipping %>
                        <% } %>
                    </span>
                </div>
                <div class="summary-row">
                    <span>Tax</span>
                    <span>₹ <%= tax %></span>
                </div>

                <div class="coupon-section">
                    <p>Coupon Code</p>
                    <div class="coupon-input">
                        <input type="text" placeholder="Enter coupon code">
                        <button class="btn-apply">Apply</button>
                    </div>
                </div>

                <div class="total-row">
                    <span class="total-amount">₹ <%= total %></span>
                </div>
            </div>
            <button class="btn-place-order">Place Order</button>
        </aside>
    </div>
</main>

<!-- Mobile Bottom Navbar -->
<div class="mobile-bottom-nav">
    <a href="../home/index.html" class="nav-item">
        <i class="fa-solid fa-house"></i>
        <span>Home</span>
    </a>
    <a href="../shop/index.html" class="nav-item">
        <i class="fa-solid fa-bag-shopping"></i>
        <span>Shop</span>
    </a>
    <a href="../cart/index.html" class="nav-item">
        <i class="fa-solid fa-cart-shopping"></i>
        <span>Cart</span>
    </a>
    <a href="../wishlist/index.html" class="nav-item">
        <i class="fa-solid fa-heart"></i>
        <span>Wishlist</span>
    </a>
    <a href="../profile/index.html" class="nav-item">
        <i class="fa-solid fa-user"></i>
        <span>Profile</span>
    </a>
</div>
<% if (typeof swalMessage !== "undefined" && swalMessage) { %>
<span id="swalMessage" style="display:none;">
    <%= swalMessage %>
</span>
<% } %>

<script>
    let messageElement = document.getElementById("swalMessage");

    if (messageElement && messageElement.innerText.trim() !== "") {
    swal(messageElement.innerText);
    }

    function editAddress(id) {
        window.location.href = `/editAddress?id=${id}&from=checkout`
    }
</script>