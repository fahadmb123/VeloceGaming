<link rel="stylesheet" href="/css/user/login.css">
<header>
    <div class="logo">
        <div class="logo-icon">
            <i class="fa-solid fa-check"></i>
        </div>
        <div class="logo-text">
            <span class="brand">VELOCE</span>
            <span class="sub-brand">GAMING</span>
        </div>
    </div>
    <nav>
        <a href="/">Home</a>
        <a href="/shop">Shop</a>
        <a href="/signup">Sign Up</a>
    </nav>
</header>

<main>
    <div class="login-container">
        <h1>Log in</h1>
        <p>Enter your details below</p>

        <% if (typeof message !== "undefined" && message) { %>
            <p style="color:red;"><%= message %></p>
        <% } %>

        <form id="registerForm" action="/login" method="post" >
            <div id="emailDiv" class="form-group">
                <label>Email</label>
                <input id="email" name="email" type="email" placeholder="Enter your email">
                <p style="color: red;font-size: 13px;font-weight: normal;margin-top: 2px !important;display: none;">Email Requierd</p>
            </div>

            <div id="passwordDiv" class="form-group password-group">
                <label>Password</label>
                <div class="input-wrapper password-input-wrapper">
                    <input minlength="6"  type="password" id="password" placeholder="Enter your password" name="password">
                    
                    <span class="toggle-password" onclick="togglePassword('password', this)">Show</span>
                    
                </div>
                <p style="color: red;font-size: 13px;font-weight: normal;margin-top: 2px !important;display: none;">Password Requierd</p>
            </div>

            <div class="forgot-password">
                <a href="/emailEntry">Forgot Password?</a>
            </div>

            <button type="submit" class="btn-submit">Log in</button>

              <div class="divider">
                    <span>OR</span>
                </div>
            <a href="/google" style="text-decoration: none;">
                <div class="sso-options">
                    <button type="button" class="btn-sso btn-google">
                        <i class="fa-brands fa-google"></i> Login with Google
                    </button>
                </div>
            </a>
                
            <div class="signup-link">
                Don't have an account? <a href="/signup">Sign up</a>
            </div>
        </form>
    </div>
    <% if (typeof swalMessage !== "undefined" && swalMessage) { %>
    <span id="swalMessage" style="display:none;">
        <%= swalMessage %>
    </span>
    <% } %>
</main>
<script src="/js/user/login.js"></script>