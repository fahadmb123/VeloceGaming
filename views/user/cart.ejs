<link rel="stylesheet" href="/css/user/cart.css">

<%
let outOfStock = false

if (cartItems) {
  outOfStock = cartItems.items.some(item => item.variantId.stock === 0)
}

%>

<!-- Header -->
<header>





<% if (error_msg.length > 0) { %>

    <span id="flashErrorMessage" style="display:none;">
        <%= error_msg[0] %>
    </span>
    
<% } %>

<% if (success_msg.length > 0) { %>
    <span id="flashSuccessMessage" style="display:none;">
        <%= success_msg[0] %>
    </span>
<% } %>



    <div class="header-container">
        <div class="logo">
            <div class="logo-icon"><i class="fa-solid fa-check"></i></div>
            <div class="logo-text">
                <span class="brand">VELOCE</span>
                <span class="sub-brand">GAMING</span>
            </div>
        </div>

        <nav>
            <a href="/">Home</a>
            <a href="/shop">Shop</a>
        </nav>

        <div class="header-icons">
            <a href="/wishlist"><i class="fa-regular fa-heart"></i></a>
            <a href="/cart" class="active"><i class="fa-solid fa-cart-shopping"></i></a>
            <div class="user-menu">
                <% if (user) { %>
                    
                    <a style="text-decoration: none;" href="/profile">
                        <div class="profile-circle">
                        <% if (user.profileImage){ %>
                        <img src="<%= user.profileImage %>" 
                           style="width:100%; height:100%; object-fit:cover; border-radius:50%;">
                    <% }  else { %>
                    <%= user.name.charAt(0).toUpperCase() %> 
                    <% } %> 
                    </div>
                </a>
                <% } else { %>
                    <div style="display: none;" class="profile-circle"></div>
                <% } %>
            </div>
        </div>
    </div>
</header>

<main class="cart-main">
    <h1 class="page-title">Cart</h1>

    <div class="cart-layout">
        <div class="cart-items">
            <% if (cartItems.items.length !== 0) { %>
            <% cartItems.items.forEach((item,index) => {  %>
                <% if (item.variantId && item.variantId.status && !item.variantId.productId.isDeleted && !item.variantId.productId.categoryId.isDeleted) { %>
            <div id="cart-<%= item.variantId._id %>" class="cart-card"   data-price="<%= item.variantId.offeredPrice %>">
                
                
                <div class="product-image">
                <a style="text-decoration: none;" href="/product/<%= item.variantId._id %>" >
                    <img src="<%= item.variantId.images[0] %>" style="width:100%; height:100%; object-fit:cover; ;">
                </a>
                </div>
                <div class="product-info">
                    <div class="product-header">
                        <h3><%= item.variantId.productId.name %></h3>
                        <button onclick="handleRemove(event,'<%= item.variantId._id %>')"  class="remove-btn"><i class="fa-regular fa-trash-can"></i></button>
                    </div>
                    <div class="product-main">
                        <div class="price-section">
                            <span id="offferedInputPrice"  class="price">₹ <%= item.variantId.offeredPrice.toLocaleString("en-IN") %></span>
                            <div class="attributes">
                                <p>
                                    <% item.variantId.attributes.forEach ( (attr,index) => { %>
                                        <% if (attr.value) { %>
                                            <% if (attr.key == "color") { %>
                                                <%= attr.key %> : <%= item.variantId.colorName %> <br>
                                            <% } else { %>
                                                <%= attr.key %> : <%= attr.value %> GB <br>
                                            <% } %>
                                        <% } %>
                                    <% }) %>
                                </p>
                            </div>
                            <% if (item.variantId.stock <= 5) {  %>
                        <span class="out-of-stock-badge">
                    <% if (item.variantId.stock == 0) { %>
                        Out of Stock
                    <% } else { %>
                        <%= item.variantId.stock %> Left
                    <% } %>
                    </span>
                <% } %>
                        </div>
                        <div class="subtotal-section">
                            <p  class="itemSubtotalInput subtotal-label">Subtotal : <span>₹ <%= item.subtotal.toLocaleString("en-IN") %></span></p>
                            <div class="quantity-control">
                                <span class="qty-label">Quantity</span>
                                <div class="qty-input">
                                    <input class="quantityInput" type="text" value="<%= item.quantity %>" readonly>
                                    <div class="qty-arrows">
                                        <i onclick="incQuantity('<%= item.variantId._id %>')" class="fa-solid fa-chevron-up"></i>
                                        <i  onclick="decQuantity('<%= item.variantId._id %>')" class="fa-solid fa-chevron-down"></i>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <% } %>
            <% })} else { %>
                <h1><pre>         No products Found</pre></h1>
            <% } %>
        </div>
        <aside class="cart-summary">
            <h2>Cart Total</h2>
            <div class="summary-details">
                <div class="summary-row">
                    <span>Subtotal</span>
                </div>
                <div class="summary-row">
                    <span>Shipping</span>
                </div>
                <div class="total-row">
                    <span id="totalInput" class="total-price">₹ <%= total.toLocaleString("en-IN") %></span>
                </div>
            </div>
            
            <% if (!outOfStock && !variantQuantityAvailable) { %>
                <a href="/checkout">
                    <button class="btn-checkout">Proceed to checkout</button>
                </a>
            <% } else { %>
                <% if (variantQuantityAvailable) { %>
                    <button class="btn-checkout" disabled>Some Product Doesn't Have That Much Quantity</button>
                <% } else { %>
                    <button class="btn-checkout" disabled>Out of Stock</button>
                <% } %>
                
            <% } %>
        </aside>
    </div>
</main>

<!-- Mobile Bottom Navbar -->
<div class="mobile-bottom-nav">
    <a href="/" class="nav-item">
        <i class="fa-solid fa-house"></i>
        <span>Home</span>
    </a>
    <a href="/shop" class="nav-item">
        <i class="fa-solid fa-bag-shopping"></i>
        <span>Shop</span>
    </a>
    <a href="/cart" class="nav-item active">
        <i class="fa-solid fa-cart-shopping"></i>
        <span>Cart</span>
    </a>
    <a href="/wishlist" class="nav-item">
        <i class="fa-solid fa-heart"></i>
        <span>Wishlist</span>
    </a>
    <a href="/profile" class="nav-item">
        <i class="fa-solid fa-user"></i>
        <span>Profile</span>
    </a>
</div>

<!-- Scripts -->
<script src="/js/user/cart.js"></script>