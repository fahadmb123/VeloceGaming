<link rel="stylesheet" href="/css/user/home.css">


<!-- Header -->
<header>
    <div class="header-container">
        <div class="logo">
            <div class="logo-icon"><i class="fa-solid fa-check"></i></div>
            <div class="logo-text">
                <span class="brand">VELOCE</span>
                <span class="sub-brand">GAMING</span>
            </div>
        </div>

        <nav>
            <a href="/">Home</a>
            <a href="/shop">Shop</a>
            
            <% if (user) { %>
                <a style="display: none;" href="/login">Log In</a>
            <% } else { %>
                <a href="/login">Log In</a>
            <% } %>    
        </nav>
        
        <div class="search-bar">
            <input type="text" id="desktopSearchInput" placeholder="What are you looking for?">
            <div class="search-icons">
                <i class="fa-solid fa-circle-xmark clear-search" id="clearDesktopSearchBtn"></i>
                <i class="fa-solid fa-magnifying-glass" id="searchIconDesktop"></i>
            </div>
        </div>
       
        <div class="header-icons">
            
            <% if (user) { %>
                <a href="/wishlist"><i class="fa-regular fa-heart"></i></a>
                <a style="text-decoration: none;" href="/cart" class="cart-icon-wrapper">
                <i class="fa-solid fa-cart-shopping"></i>
                <% if (Number(cartCount) > 0) { %>
                    <span class="cart-badge"><%= cartCount %></span>
                <% } %>
               </a>
            <% } %>
                 
            <div class="user-menu">
                <% if (user) { %>
                    
                    <a style="text-decoration: none;" href="/profile">
                        <div class="profile-circle">
                        <% if (user.profileImage){ %>
                        <img src="<%= user.profileImage %>" 
                           style="width:100%; height:100%; object-fit:cover; border-radius:50%;">
                    <% }  else { %>
                    <%= user.name.charAt(0).toUpperCase() %> 
                    <% } %> 
                    </div>
                </a>
                <% } else { %>
                    <div style="display: none;" class="profile-circle"></div>
                <% } %>
            </div>
        </div>
    </div>
</header>

<main>

    <!-- Mobile Search Bar -->
        <div class="mobile-search">
            <div class="search-wrapper">
                <input type="text" id="shopSearchInput" placeholder="What are you looking for?">
                <div class="search-icons">
                    <i class="fa-solid fa-circle-xmark clear-search" id="clearSearchBtn"></i>
                    <i class="fa-solid fa-magnifying-glass"></i>
                </div>
            </div>
        </div>
    
    <!-- Category Section -->
    <section class="section categories">
        <div class="section-header">
            <div class="red-line"></div>
            <h2>Browse By Category</h2>
        </div>

        <div class="category-carousel-container">
                <button class="carousel-nav-btn prev-btn" id="prevBtn"><i class="fa-solid fa-chevron-left"></i></button>
                <div class="category-grid" id="categoryCarousel">
                    <% categories.forEach((category,index)=>{ %>
                        <% if (!category.isDeleted) { %>
            
                    <div class="category-card">
                        <div class="cat-content">
                            <a href="/shop?category=<%= category._id %>">
                            <div class="cat-image-wrapper">
                                <img src="<%= category.image %>" alt="Phone Category" class="category-img">
                            </div></a>
                            <h3><%= category.name %></h3>
                        </div>
                    </div>
                    
                    <% }}) %>
                </div>
                <button class="carousel-nav-btn next-btn" id="nextBtn"><i
                        class="fa-solid fa-chevron-right"></i></button>
            </div>
    </section>

    <!-- Hero Section -->
    <!-- <section class="hero">
        
        <img src="/images/banner-1.png" alt="Hero Banner" class="hero-bg">
        <div class="hero-content">
            <h1>Quality You Can Feel</h1>
            <p>Explore our premium selection of top-rated products at prices you'll love</p>
        </div>
        <a href="/shop"><button class="btn-shop-now">Shop Now</button></a>
    </section> -->

    <!-- Products Section -->
    <section class="section products">
        <div class="section-header">
            <div class="red-line"></div>
            <h2>Explore Our Products</h2>
        </div>

        <div class="product-grid">
            <% variants.forEach((variant,index)=>{%>
                <% if (variant && variant.status && !variant.productId.isDeleted && !variant.productId.categoryId.isDeleted) {%>
                    
            <div class="product-card">
            <a style="text-decoration: none;" href="/product/<%= variant._id %>">
                <div class="product-image">
                    <button onclick="toggleWishlist(event,'<%= variant._id %>',this)" class="wishlist-btn <%= wishlistVariantIds.includes(variant._id.toString()) ? 'active' : '' %>" title="Add to Wishlist"><i class="<%= wishlistVariantIds.includes(variant._id.toString()) 
                        ? 'fa-solid fa-heart' 
                        : 'fa-regular fa-heart' %>">
                    </i></button>
                    
                
                    <img src="<%= variant.images[0] %>" style="width:100%; height:100%; object-fit:cover; ;">
               
                </div> 
            </a>
                <div class="product-info">
                    <h3><%= variant.productId.name %></h3>
                    <div class="price">
                        <span class="current-price">₹ <%= variant.offeredPrice.toLocaleString("en-IN") %></span>
                        <span class="discount">-<%= variant.productId.offer %>% OFF</span>
                    </div>
                    <span class="old-price">₹ <%= variant.price.toLocaleString("en-IN") %></span>
                </div>
            </div>
            
            <%}%>
            <%})%>

        </div>

        <div class="view-all-container">
            <a href="/shop"><button class="btn-view-all">View All Products</button></a>
        </div>
    </section>

    <!-- Features Section -->
    <section class="features">
        <div class="feature-item">
            <div class="icon-circle">
                <i class="fa-solid fa-truck-fast"></i>
            </div>
            <div class="feature-text">
                <h4>Free Delivery</h4>
                <p>FREE AND FAST DELIVERY</p>
            </div>
        </div>
        <div class="feature-item">
            <div class="icon-circle">
                <i class="fa-solid fa-headset"></i>
            </div>
            <div class="feature-text">
                <h4>24/7 Customer Service</h4>
                <p>Always here to help you</p>
            </div>
        </div>
    </section>
</main>

<footer>
    <div class="footer-content">
        <div class="footer-col">
            <div class="logo">
                <div class="logo-icon"><i class="fa-solid fa-check"></i></div>
                <div class="logo-text">
                    <span class="brand" style="color: white;">VELOCE</span>
                    <span class="sub-brand" style="color: white;">GAMING</span>
                </div>
            </div>
            <p>Your ultimate gaming gear destination</p>
        </div>
        <div class="footer-col">
            <h4>Support</h4>
            <a href="#">Contact Us</a>
            <a href="#">FAQs</a>
            <a href="#">Return Policy</a>
            <a href="#">Shipping Info</a>
        </div>
        <div class="footer-col">
            <h4>Account</h4>
            <a href="#">Login</a>
            <a href="#">Sign Up</a>
            <a href="/profile">My Account</a>
            <a href="/wishlist">Wishlist</a>
        </div>
        <div class="footer-col">
            <h4>Info</h4>
            <div class="contact-info">
                <i class="fa-regular fa-envelope"></i> support@veloce.com
            </div>
            <div class="contact-info">
                <i class="fa-solid fa-phone"></i> +1 (555) 123-4567
            </div>
            <div class="contact-info">
                <i class="fa-solid fa-location-dot"></i> Gaming Street, Tech City
            </div>
        </div>
    </div>
    <div class="footer-bottom">
        <p>&copy; 2024 VELOCE GAMING. All rights reserved.</p>
        <div class="footer-links">
            <a href="#">Privacy Policy</a>
            <a href="#">Terms of Service</a>
            <a href="#">Cookie Policy</a>
        </div>
    </div>
    <% if (typeof swalMessage !== "undefined" && swalMessage) { %>
    <span id="swalMessage" style="display:none;">
        <%= swalMessage %>
    </span>
    <% } %>


     <div class="mobile-bottom-nav">
        <a href="/" class="nav-item active">
            <i class="fa-solid fa-house"></i>
            <span>Home</span>
        </a>
        <a href="/shop" class="nav-item">
            <i class="fa-solid fa-bag-shopping"></i>
            <span>Shop</span>
        </a>
        <a href="/cart" class="nav-item">
            <i class="fa-solid fa-cart-shopping"></i>
            <span>Cart</span>
        </a>
        <a href="/wishlist" class="nav-item">
            <i class="fa-solid fa-heart"></i>
            <span>Wishlist</span>
        </a>
        <a href="/profile" class="nav-item">
            <i class="fa-solid fa-user"></i>
            <span>Profile</span>
        </a>
    </div>

</footer>
<script src="/js/user/home.js"></script>