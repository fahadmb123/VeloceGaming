<link rel="stylesheet" href="/css/user/orderHistory.css">

<!-- Header -->
<header>
    <div class="header-container">
        <div class="logo">
            <div class="logo-icon"><i class="fa-solid fa-check"></i></div>
            <div class="logo-text">
                <span class="brand">VELOCE</span>
                <span class="sub-brand">GAMING</span>
            </div>
        </div>

        <nav>
            <a href="/">Home</a>
            <a href="/shop">Shop</a>
        </nav>

        <div class="header-icons">
            <a href="/wishlist"><i class="fa-regular fa-heart"></i></a>
            <a href="/cart"><i class="fa-solid fa-cart-shopping"></i></a>
            <div class="user-menu">
                <% if (user) { %>
                    
                    <a style="text-decoration: none;" href="/profile">
                        <div class="profile-circle">
                        <% if (user.profileImage){ %>
                        <img src="<%= user.profileImage %>" 
                           style="width:100%; height:100%; object-fit:cover; border-radius:50%;">
                    <% }  else { %>
                    <%= user.name.charAt(0).toUpperCase() %> 
                    <% } %> 
                    </div>
                </a>
                <% } else { %>
                    <div style="display: none;" class="profile-circle"></div>
                <% } %>
            </div>
        </div>
    </div>
</header>

<main class="container">
    <div class="page-header myOrderClass">
        <nav class="breadcrumb">
            <pre>   </pre><a href="/">Home</a>
            <span>/</span>
            <a href="/profile">Profile</a>
            <span>/</span>
            <span>My Orders</span>
        </nav>
        <h1><pre>     My Orders</pre></h1>
        <p><pre>      Track, manage and return your recent electronics purchases.</pre></p>
    </div>

    <div class="orders-toolbar">
        <div class="toolbar-filters">
            <div class="filter-group">
                <i class="fa-solid fa-filter"></i>
                <select onchange="window.location.href='/orderHistory?filter=' + this.value + '&search=<%= search %>'" id="status-filter" class="status-select">
                    <option value="all" <%= filter === 'all' ? 'selected' : '' %>>All Status</option>
                    <option  value="placed" <%= filter === 'placed' ? 'selected' : '' %>>placed</option>
                    <option  value="ofd" <%= filter === 'ofd' ? 'selected' : '' %>>Out For Delivary</option>
                    <option  value="delivered" <%= filter === 'delivered' ? 'selected' : '' %>>Delivered</option>
                    <option  value="cancelled" <%= filter === 'cancelled' ? 'selected' : '' %>>Cancelled</option>
                    <option  value="returned" <%= filter === 'returned' ? 'selected' : '' %>>Returned</option>
                </select>
            </div>
                <form class="search-orders" action="/orderHistory" method="GET" id="search-form">
                    <input type="hidden" name="filter" value="<%= filter %>">
                    <input name="search" value="<%= search %>" type="text" id="order-search" placeholder="Order ID or product name...">
                    <i class="fa-solid fa-circle-xmark" id="search-clear"
                        style="display: none; cursor: pointer; color: #94A3B8; font-size: 1rem; transition: color 0.2s;"></i>
                    <button type="submit"
                        style="background: none; border: none; cursor: pointer; color: inherit; padding: 0; display: flex; align-items: center;">
                        <i class="fa-solid fa-magnifying-glass"></i>
                    </button>
                </form>
        </div>
    </div>

    <div class="orders-list">

        <!-- Order Card 2: Delivered -->
         <% if (orders.length != 0) { %>
        <div class="order-card">
            
            <% orders.forEach ((order,index) => { %>
                <% let item = order.item %>
            <div class="order-card-header">
                <div class="header-info">
                    <div class="info-block">
                        <label>ORDER PLACED</label>
                        <span><%= new Date(order.createdAt).toLocaleDateString("en-US",{
                        year : "numeric",
                        month : "long",
                        day : "numeric"
                    }) %></span>
                    </div>
                    <div class="info-block">
                        <label>TOTAL PRICE</label>
                        <span class="price">
                            <% let finalAmount = item?.total - item?.couponDiscount %>
                            ₹ <%= finalAmount.toLocaleString("en-IN") %>
                        </span>
                    </div>
                    <div class="info-block">
                        <label>ORDER ID</label>
                        <span><%= order.orderId %></span>
                    </div>
                </div>
                <div class="order-status-badge <%= (item.status === "placed" || item.status === "shipped") ? "ongoing" : item.status === "returned" ? "cancelled" : item.status %>">
                    <i class="fa-solid fa-circle-check"></i>
                    <% if (item.status === "ofd") { %>
                        OUT FOR DELIVERY
                    <% } else { %>
                        <%= item.status.toUpperCase() %>
                    <% } %>
                </div>
            </div>
            <div class="order-card-body">
                <div class="product-info">
                    <div style="width:300px; height:150px;">
                        <img src="<%= item.productImage %>" style="width:100%; height:100%; object-fit:cover;">
                    </div>
                    <div class="product-details">
                        <h3><%= item.productName %></h3>
                        <% item.attributes.forEach ( (attr,index) => { %>
                            <% if (attr.value) { %>
                                <p class="specs"><% if (attr.key == "color") { %>
                                   <%= attr.key %> : <%= item.colorName %>
                                <% } else { %>
                                    <%= attr.key.toUpperCase() %> : <%= attr.value %>
                                <% } %>
                                </p>
                            <% } %>
                        <% }) %>
                        
                        <!-- <div class="post-buy-actions">
                            <a href="#"><i class="fa-solid fa-rotate-left"></i> Buy it again</a>
                            <a href="#"><i class="fa-regular fa-star"></i> Write a review</a>
                        </div> -->
                    </div>
                </div>
                <div class="order-actions">
                    <% if (item.status === "delivered") { %>
                        <a href="/downloadInvoice?orderId=<%= order._id %>&itemId=<%= item._id %>">
                        <button class="btn btn-outline">Download Invoice</button>
                    </a>
                    <% } %>
                    <button onclick="viewDetails('<%= item._id %>')" class="btn btn-secondary">View Details</button>
                </div>
            </div>
            
            <% }) %>
        </div>
        <% } else { %>
                <h1><pre>     No Orders</pre></h1>
            <% } %>
    </div>

    <!-- Pagination -->
    <div class="pagination">
        <% if (currentPage > 1) { %>
            <a style="text-decoration: none;" href="/orderHistory?page=<%= currentPage - 1 %>
                <% if (typeof search !== 'undefined') { %>&search=<%= search %><% } %>
                <% if (typeof filter !== 'undefined') { %>&filter=<%= filter %><% } %>">

                <button class="page-btn">
                    <i class="fa-solid fa-chevron-left"></i>
                </button>
            </a>
        <% } %>

        <%
            const visiblePages = 3
            let start = currentPage
            let end = currentPage + visiblePages - 1

            if (end > totalPages) {
                end = totalPages
                start = Math.max(1, totalPages - visiblePages + 1)
            }
        %>

        <% for(let i = start; i <= end; i++) { %>
            <a style="text-decoration: none;"  href="/orderHistory?page=<%= i %>

                <% if (typeof search !== 'undefined') { %>&search=<%= search %><% } %>
                <% if (typeof filter !== 'undefined') { %>&filter=<%= filter %><% } %>">
                <button class="page-btn <%= currentPage === i ? 'active' : '' %>">
                    <%= i %>
                </button>
            </a>
        <% } %>

        <% if (end < totalPages) { %>
            <span>...</span>
        <% } %>

        <% if (currentPage < totalPages) { %>

            <a style="text-decoration: none;" href="/orderHistory?page=<%= currentPage + 1 %>

                <% if (typeof search !== 'undefined') { %>&search=<%= search %><% } %>
                <% if (typeof filter !== 'undefined') { %>&filter=<%= filter %><% } %>">
                <button class="page-btn">
                    <i class="fa-solid fa-chevron-right"></i>
                </button>
            </a>
        <% } %>
    </div>
</main>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const filterSelect = document.getElementById('status-filter');
        const orderSearch = document.getElementById('order-search');
        const cards = document.querySelectorAll('.order-card');

        function applyFilters() {
            const status = filterSelect.value.toLowerCase();
            const query = orderSearch.value.toLowerCase();

            cards.forEach(card => {
                const cardCategory = card.dataset.category.toLowerCase();
                const cardName = card.dataset.name.toLowerCase();
                const cardId = card.dataset.id.toLowerCase();

                const matchesStatus = (status === 'all' || cardCategory === status);
                const matchesQuery = (cardName.includes(query) || cardId.includes(query));

                if (matchesStatus && matchesQuery) {
                    card.style.display = 'block';
                    card.style.opacity = '1';
                } else {
                    card.style.display = 'none';
                }
            });
        }

        const searchInput = document.getElementById("order-search");
        const clearBtn = document.getElementById("search-clear");

        searchInput.addEventListener("input", () => {
            clearBtn.style.display = searchInput.value ? "block" : "none";
        });
        if (searchInput.value.trim() !== "") {
            clearBtn.style.display = "block";
        }
        searchInput.addEventListener("input", () => {
            clearBtn.style.display = searchInput.value.trim() !== "" ? "block" : "none";
        })


        clearBtn.addEventListener("click", () => {
            searchInput.value = "";
            clearBtn.style.display = "none";
            searchInput.focus();
            window.location.href = "/orderHistory?filter=<%= filter %>"
        })



        
    });

    async function viewDetails(id) {
        window.location.href=`/orderDetails?id=${id}`
    }
</script>