<link rel="stylesheet" href="/css/admin/login.css">



<div class="background-icons">
    <i class="fa-solid fa-cart-shopping icon-1"></i>
    <i class="fa-solid fa-briefcase icon-2"></i>
    <i class="fa-solid fa-cash-register icon-3"></i>
    <i class="fa-solid fa-bag-shopping icon-4"></i>
    <i class="fa-solid fa-cart-shopping icon-5"></i>
    <i class="fa-solid fa-cash-register icon-6"></i>
</div>

<main class="login-wrapper">
    <div class="login-card">
        <header class="logo-section">
            <div class="logo-box">
                <div class="logo-circle">
                    <i class="fa-solid fa-check"></i>
                </div>
            </div>
            <div class="logo-text">
                <span class="brand-name">VELOCE</span>
                <span class="sub-brand">GAMING</span>
            </div>
        </header>

        <h1>Admin Login</h1>

        <% if (typeof message !== "undefined" && message) { %>
            <p style="color:red;"><%= message %></p>
        <% } %>

        <form action="/admin/login" method="post" onclick="return formValidate()">
            <div class="form-group">
                <label for="email">Email</label>
                <input name="email" type="email" id="email" placeholder="Email">
            </div>

            <div class="form-group">
                <label for="password">Password</label>
                <div class="password-input">
                    <input minlength="6" type="password" id="password" name="password" placeholder="Password">
                    <i class="fa-regular fa-eye eye-toggle" id="togglePassword"></i>
                </div>
            </div>

            <button  type="submit" class="btn-login">Login</button>
        </form>
    </div>

    <% if (typeof swalMessage !== "undefined" && swalMessage) { %>
    <span id="swalMessage" style="display:none;">
        <%= swalMessage %>
    </span>
    <% } %>

</main>
<script src="/js/admin/login.js">
</script>