<link rel="stylesheet" href="/css/admin/categoryManagement.css">


<div id="admin-spinner" class="spinner-overlay" style="display:none;">
    <div class="spinner"></div>
</div>
<div class="dashboard-container">
    <!-- Sidebar -->
    <aside class="sidebar">
        <div class="sidebar-header">
            <div class="logo">
                <div class="logo-circle">
                    <i class="fa-solid fa-check"></i>
                </div>
                <div class="logo-text">
                    <span class="brand">VELOCE</span>
                    <span class="sub-brand">GAMING</span>
                </div>
            </div>
        </div>

        <nav class="sidebar-nav">
            <ul>
                <li><a href="/admin/dashboard"><span>DashBoard</span></a></li>
                <li><a href="/admin/userManagement"><span>Users</span></a></li>
                <li class="active"><a href="#"><span>Category</span></a></li>
                <li><a href="/admin/orderManagement"><span>Order</span></a></li>
                <li><a href="/admin/productManagement"><span>Product</span></a></li>
                <li><a href="/admin/couponManagement"><span>Coupon</span></a></li>
                <li><a href="/admin/salesManagement"><span>Report</span></a></li>
                <!-- <li><a href="/admin/bannerManagement"><span>Banner</span></a></li> -->
            </ul>
        </nav>
<a href="/admin/logout" style="text-decoration: none;">
        <div class="sidebar-footer">
            <button class="btn-logout">Log out</button>
        </div></a>
    </aside>

    <!-- Main Content -->
    <main class="main-content">
        <header class="main-header">
            <h1>Category Management</h1>
        </header>

        <section class="content-card">
            <div class="table-controls">
                <div class="search-box">
                    <form action="/admin/categoryManagement" method="GET" id="searchForm">
                        <input type="hidden" name="filter" value="<%= filter %>">
                        <div class="search-content">
                            <div class="search-wrapper">
                                <i class="fa-solid fa-magnifying-glass search-icon"></i>
                                <input value="<%= search %>" type="text" name="search" id="searchInput" placeholder="Search..."
                                    autocomplete="off">
                                <button type="button" id="clearSearch" class="clear-btn">&times;</button>
                            </div>
                            <button type="submit" class="search-btn">Search</button>
                        </div>
                    </form>
                </div>

                <div class="filter-box">
                    <button class="add-btn" onclick="openCategoryModal('add')"><i class="fa-solid fa-plus"></i> Add
                        Category</button>
                        <select class="filter-select" onchange="window.location.href='/admin/categoryManagement?filter=' + this.value + '&search=<%= search %>'">
                            <option>Filter : Status</option>
                            <option value="all" <%= filter === 'all' ? 'selected' : '' %>>All</option>
                            <option value="active" <%= filter === 'active' ? 'selected' : '' %>>Active</option>
                            <option value="inactive" <%= filter === 'inactive' ? 'selected' : '' %>>Inactive</option>
                        </select>
                    </div>
            </div>

            <div class="table-container">
                <table class="category-table">
                    <thead>
                        <tr>
                            <th>Status</th>
                            <th>Category Name</th>
                            <th>Offer</th>
                            <th>Product Count</th>
                            <th class="text-right">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% categories.forEach( (category,index) => { %>
                            
                        <tr data-category='<%= JSON.stringify(category) %>'>
                            <td>
                                <span class="status-active">
                                    <% if (!category.isDeleted) { %>
                                        Active
                                    <% } else { %>
                                        Inactive
                                    <% } %>
                                </span>
                            </td>
                            <td class="category-name"><%= category.name %></td>
                            <td class="offer-value"><% if (Number(category.offer) <= 0) { %>
                                    No Offer
                                <% } else { %>
                                    <%= category.offer%>%
                                <% } %>
                                </td>
                            <td class="product-count"><%= category.productCount %></td>
                            <td class="text-right">
                                <div class="actions-column">
                                    <button class="icon-btn edit-btn"
                                        onclick='openCategoryModal("edit", this.closest("tr"))'>
                                        <i class="fa-regular fa-pen-to-square"></i>
                                    </button>
                                    <% if (!category.isDeleted) { %>
                                        <button class="btn-block" onclick="deleteCategory('<%= category._id %>',true)">
                                            Delete <i class="fa-regular fa-trash-can"></i>
                                        </button>
                                    <% } else { %>
                                        <button class="btn-block-active" onclick="deleteCategory('<%= category._id %>',false)">
                                            Restore
                                        </button> 
                                    <% } %>
                                </div>
                            </td>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>

            <div class="pagination">
                    <div class="pagination">

                        <% if (currentPage > 1) { %>
                            <a style="text-decoration: none;" href="/admin/categoryManagement?page=<%= currentPage - 1 %>

                                <% if (typeof search !== 'undefined') { %>&search=<%= search %><% } %>
                                <% if (typeof filter !== 'undefined') { %>&filter=<%= filter %><% } %>">

                                <button class="page-arrow">
                                    <i class="fa-solid fa-chevron-left"></i>
                                </button>

                            </a>
                        <% } %>

                        <%
                            const visiblePages = 3
                            let start = currentPage
                            let end = currentPage + visiblePages - 1

                            if (end > totalPages) {
                                end = totalPages
                                start = Math.max(1, totalPages - visiblePages + 1)
                            }
                        %>


                        <% for(let i = start; i <= end; i++) { %>
                            <a style="text-decoration: none;"  href="/admin/categoryManagement?page=<%= i %>

                                <% if (typeof search !== 'undefined') { %>&search=<%= search %><% } %>
                                <% if (typeof filter !== 'undefined') { %>&filter=<%= filter %><% } %>">

                                <button class="page-num <%= currentPage === i ? 'active' : '' %>">
                                    <%= i %>
                                </button>
                            </a>
                        <% } %>


                        <% if (end < totalPages) { %>
                            <span>...</span>
                        <% } %>


                        <% if (currentPage < totalPages) { %>
                            <a style="text-decoration: none;" href="/admin/categoryManagement?page=<%= currentPage + 1 %>

                                <% if (typeof search !== 'undefined') { %>&search=<%= search %><% } %>
                                <% if (typeof filter !== 'undefined') { %>&filter=<%= filter %><% } %>">

                                <button class="page-arrow">
                                    <i class="fa-solid fa-chevron-right"></i>
                                </button>
                            </a>
                        <% } %>
                    </div>      
                </div>
        </section>
    </main>
</div>

<div id="categoryModal" class="modal">
    <div class="modal-content">
        <div class="modal-header">
            <h2 id="modalTitle">Edit Category Details</h2>
        </div>
        <form id="categoryForm">
            <div id="nameDiv" class="form-group">
                <label>Category Name</label>
                <input type="text" id="catName" placeholder="Enter name">
                <p style="color: red;font-size: 13px;font-weight: normal;margin-top: 2px !important;display: none;">Name Requierd At Lease 3 letters</p>
            </div>
            <div id="offerDiv" class="form-group">
                <label>Offer (%)</label>
                <input type="text" id="catOffer" placeholder="Enter offer">
                <p style="color: red;font-size: 13px;font-weight: normal;margin-top: 2px !important;display: none;">Incorrect Offer</p>
            </div>
            <div id="imageDiv" class="form-group">
                <label>Category Image</label>
                <!-- <div class="image-preview-container">
                    <img id="catImagePreview" src="" alt="Preview" style="display: none;">
                    
                </div> -->
                <div class="image-preview-container">
                    <img id="catImagePreview" src="" alt="Preview" style="display: none;">
                </div>
                <p style="color: red;font-size: 13px;font-weight: normal;margin-top: 2px !important;display: none;">Image Requierd</p>
                <input type="file" id="catImageInput" hidden accept="image/*" onchange="previewCategoryImage(this)">
                <button type="button" class="btn-add-img"
                    onclick="document.getElementById('catImageInput').click()">Add</button>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn-cancel" onclick="closeModal()">Cancel</button>
                <button type="submit" class="btn-save">Save</button>
            </div>
        </form>
    </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.5.13/cropper.min.js"></script>
<script src="/js/admin/categoryManagement.js"></script>
