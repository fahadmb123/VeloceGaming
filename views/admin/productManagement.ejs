<link rel="stylesheet" href="/css/admin/productManagement.css">
</head>

<body>
    <!-- Loading Spinner -->
<div id="admin-spinner" class="spinner-overlay" style="display:none;">
    <div class="spinner"></div>
</div>
    <div class="dashboard-container">
        <!-- Sidebar -->
        <aside class="sidebar">
            <div class="sidebar-header">
                <div class="logo">
                    <div class="logo-circle">
                        <i class="fa-solid fa-check"></i>
                    </div>
                    <div class="logo-text">
                        <span class="brand">VELOCE</span>
                        <span class="sub-brand">GAMING</span>
                    </div>
                </div>
            </div>

            <nav class="sidebar-nav">
                <ul>
                    <li><a href="/admin/dashboard"><span>DashBoard</span></a></li>
                    <li><a href="/admin/userManagement"><span>Users</span></a></li>
                    <li><a href="/admin/categoryManagement"><span>Category</span></a></li>
                    <li><a href="/admin/orderManagement"><span>Order</span></a></li>
                    <li class="active"><a href="#"><span>Product</span></a></li>
                    <li><a href="/admin/couponManagement"><span>Coupon</span></a></li>
                    <li><a href="/admin/salesManagement"><span>Report</span></a></li>
                    <!-- <li><a href="#"><span>Banner</span></a></li> -->
                </ul>
            </nav>

            <a href="/admin/logout" style="text-decoration: none;">
            <div class="sidebar-footer">
                <button class="btn-logout">Log out</button>
            </div></a>
        </aside>

        <!-- Main Content -->
        <main class="main-content">
            <header class="main-header">
                <h1>Product Management</h1>
            </header>

            <section class="content-card">
                <div class="table-controls">
                    <div class="search-box">
                        <form action="/admin/productManagement" method="GET" id="searchForm">
                            <input type="hidden" name="fitler" value="<%= filter %>">
                            <div class="search-content">
                                <div class="search-wrapper">
                                    <i class="fa-solid fa-magnifying-glass search-icon"></i>
                                    <input value="<%= search %>" type="text" name="search" id="searchInput" placeholder="Search..."
                                        autocomplete="off">
                                    <button type="button" id="clearSearch" class="clear-btn">&times;</button>
                                </div>
                                <button type="submit" class="search-btn">Search</button>
                            </div>
                        </form>
                    </div>

                    <div class="filter-box">
                        <button class="add-btn" onclick="openProductModal('add')"><i class="fa-solid fa-plus"></i> Add
                            Product</button>
                        <select class="filter-select" onchange="window.location.href='/admin/productManagement?filter=' + this.value + '&search=<%= search %>'">
                            <option>Filter : Status</option>
                            <option value="all" <%= filter === 'all' ? 'selected' : '' %>>All</option>
                            <option value="active" <%= filter === 'active' ? 'selected' : '' %>>Active</option>
                            <option value="inactive" <%= filter === 'inactive' ? 'selected' : '' %>>Inactive</option>
                        </select>
                    </div>
                </div>




                <div class="table-container">
                    <table class="product-table">
                        <thead>
                            <tr>
                                <th>Status</th>
                                <th>Category</th>
                                <th>Product Name</th>

                                <th>Offer</th>
                                <th>Variants</th>
                                <th class="text-right">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% products.forEach((product,index) => { %>
                            <tr data-id="<%= product._id %>">
                                <td><span class="status-active">
                                    <% if (!product.isDeleted) { %>
                                        Active
                                    <% } else { %>
                                        Inactive
                                    <% } %>
                                </span></td>
                                <td class="category-name"><%= product.categoryId.name %></td>
                                <td class="product-name"><%= product.name %></td>

                                <td class="offer-value"><% if (Number(product.offer) <= 0) { %>
                                    No Offer
                                <% } else { %>
                                    <%= product.offer%>%
                                <% } %></td>
                                <td class= "stock-value" ><%= product.variantCount %></td>
                                <td class="text-right">
                                    <div class="actions-column">
                                        <button class="icon-btn edit-btn"
                                            onclick="openProductModal('edit', '<%= product._id %>')">
                                            <i class="fa-regular fa-pen-to-square"></i>
                                        </button>
                                        <% if (!product.isDeleted) { %>
                                        <button class="btn-block" onclick="deleteProduct('<%= product._id %>',true)">
                                            Delete <i class="fa-regular fa-trash-can"></i>
                                        </button>
                                        <% } else { %>
                                            <button class="btn-block-active" onclick="deleteProduct('<%= product._id %>',false)">
                                            Restore
                                            </button>
                                        <% } %>
                                    </div>
                                </td>
                            </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>

                <div class="pagination">
                    <div class="pagination">


                        <% if (currentPage > 1) { %>
                            <a style="text-decoration: none;" href="/admin/productManagement?page=<%= currentPage - 1 %>

                                <% if (typeof search !== 'undefined') { %>&search=<%= search %><% } %>
                                <% if (typeof filter !== 'undefined') { %>&filter=<%= filter %><% } %>">

                                <button class="page-arrow">
                                    <i class="fa-solid fa-chevron-left"></i>
                                </button>

                            </a>
                        <% } %>

                        <%
                            const visiblePages = 3;
                            let start = currentPage;
                            let end = currentPage + visiblePages - 1;

                            if (end > totalPages) {
                                end = totalPages;
                                start = Math.max(1, totalPages - visiblePages + 1);
                            }
                        %>


                        <% for(let i = start; i <= end; i++) { %>
                            <a style="text-decoration: none;"  href="/admin/productManagement?page=<%= i %>

                                <% if (typeof search !== 'undefined') { %>&search=<%= search %><% } %>
                                <% if (typeof filter !== 'undefined') { %>&filter=<%= filter %><% } %>">

                                <button class="page-num <%= currentPage === i ? 'active' : '' %>">
                                    <%= i %>
                                </button>
                            </a>
                        <% } %>


                        <% if (end < totalPages) { %>
                            <span>...</span>
                        <% } %>


                        <% if (currentPage < totalPages) { %>
                            <a style="text-decoration: none;" href="/admin/productManagement?page=<%= currentPage + 1 %>

                                <% if (typeof search !== 'undefined') { %>&search=<%= search %><% } %>
                                <% if (typeof filter !== 'undefined') { %>&filter=<%= filter %><% } %>">

                                <button class="page-arrow">
                                    <i class="fa-solid fa-chevron-right"></i>
                                </button>
                            </a>
                        <% } %>

                    </div>  
                </div>
            </section>
        </main>
    </div>

    <!-- Product Modal -->
    <div id="productModal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h2 id="productModalTitle">Add Product</h2>
                <button type="button" class="modal-close-btn" onclick="closeProductModal()">&times;</button>
            </div>
            <form id="productForm">
                <div id="nameDiv" class="form-group">
                    <label>Product Name</label>
                    <input type="text" id="prodName" placeholder="Enter product name">
                    <p style="color: red;font-size: 13px;font-weight: normal;margin-top: 2px !important;display: none;">Name Requierd At Least 3 letters</p>
                </div>

                <div class="form-row-3">
                    <div id="categoryDiv" class="form-group">
                        <label>Category</label>
                        <div class="custom-select">
                            <select id="prodCategory">
                                <option value="">Select Category</option>
                                <% categories.forEach((category,index)=>{ %>
                                    <% if (!category.isDeleted) { %>
                                <option value="<%= category._id %>"><%= category.name %></option>
                                     <% } %>
                                <% }) %>
                            </select>
                            <i class="fa-solid fa-chevron-down select-arrow"></i>
                        </div>
                         <p style="color: red;font-size: 13px;font-weight: normal;margin-top: 2px !important;display: none;">Please Select Valid Category</p>
                    </div>
                    <div id="offerDiv" class="form-group">
                        <label>Offer (%)</label>
                        <input type="text" id="prodOffer" placeholder="00">
                        <p style="color: red;font-size: 13px;font-weight: normal;margin-top: 2px !important;display: none;">Incorrect Offer</p>
                    </div>
                    <div class="form-group">
                        <label>Show on Homepage</label>
                        <div class="custom-select">
                            <select id="prodHomepage">
                                <option value=false>No</option>
                                <option  value=true>Yes</option>
                            </select>
                            <i class="fa-solid fa-chevron-down select-arrow"></i>
                        </div>
                    </div>
                </div>

                <div class="variants-section">
                    <div class="variants-header">
                        <label>Product Variants</label>
                        <button type="button" class="btn-add-variant" id="addVariantBtn">+ Add Variant</button>
                    </div>

                    <div id="variantsContainer">
                        <div class="variant-card">
                            <div class="form-row-3">
                                <div class="form-group color-group">
                                    <label>Color</label>
                                    <div style="display:flex; gap:10px;">
                                        <input type="text" placeholder="Color Name" class="variant-color-name">
                                        <input type="color" class="variant-color-hex">
                                    </div>
                                    <p style="color: red;font-size: 13px;font-weight: normal;margin-top: 2px !important;display: none;">Color Is Required</p>
                                </div>
                                <div class="form-group">
                                    <label>RAM</label>
                                    <input type="text" placeholder="RAM" class="variant-input">
                                </div>
                                <div class="form-group">
                                    <label>Storage</label>
                                    <input type="text" placeholder="Storage" class="variant-input">
                                </div>
                            </div>
                            <div class="form-row-3">
                                <div class="form-group price-group">
                                    <label>Original Price</label>
                                    <input type="text" placeholder="0.00" class="variant-input">
                                    <p style="color: red;font-size: 13px;font-weight: normal;margin-top: 2px !important;display: none;">Price Is Required</p>
                                </div>
                                <div class="form-group stock-group">
                                    <label>Stock</label>
                                    <input type="text" placeholder="00" class="variant-input">
                                    <p style="color: red;font-size: 13px;font-weight: normal;margin-top: 2px !important;display: none;">Stock is Required</p>
                                </div>
                                <div class="form-group">
                                    <label>Status</label>
                                    <div class="custom-select">
                                        <select class="variant-status">
                                            <option value="true">Active</option>
                                            <option value="false">Inactive</option>
                                        </select>
                                        <i class="fa-solid fa-chevron-down select-arrow"></i>
                                    </div>
                                </div>
                                
                            </div>
                            <label for=""> --> The First Image Will Be The Main Image </label>
                            <div class="photo-gallery">
                                <!-- Dynamic photos will appear here -->
                                <div class="photo-add-box" onclick="this.querySelector('input').click()">
                                    <i class="fa-solid fa-plus"></i>
                                    <span>Add Photo</span>
                                    <input type="file" accept="image/*" hidden onchange="handleNewPhoto(this)">
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div id="highlightDiv" class="form-group">
                    <label>Highlights (One Per Line)</label>
                    <textarea id="prodHighlights" placeholder="Enter product Highlights" rows="2"></textarea>
                    <p style="color: red;font-size: 13px;font-weight: normal;margin-top: 2px !important;display: none;">Highlights Required Minimum 10 Letters</p>
                </div>

                <div id="serviceDiv" class="form-group">
                    <label>Services (One Per Line)</label>
                    <textarea id="prodServices" placeholder="Enter Services" rows="2"></textarea>
                    <p style="color: red;font-size: 13px;font-weight: normal;margin-top: 2px !important;display: none;">Services Required Minimum 10 Letters</p>
                </div>

                <div id="descriptionDiv" class="form-group">
                    <label>Description (One Per Line)</label>
                    <textarea id="prodDescription" placeholder="Enter Description" rows="3"></textarea>
                    <p style="color: red;font-size: 13px;font-weight: normal;margin-top: 2px !important;display: none;">Description Required Minimum 10 Letters</p>
                </div>

                <div class="modal-footer">
                    <button type="submit" class="btn-save-product">Save Product</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Crop Modal -->
    <div id="cropModal" class="crop-modal">
        <div class="crop-modal-content">
            <div class="crop-modal-header">
                <h3>Crop Image</h3>
                <button type="button" class="modal-close-btn" onclick="closeCropModal()">&times;</button>
            </div>
            <div class="crop-container">
                <img id="cropImage" alt="Crop preview">
            </div>
            <div class="crop-modal-footer">
                <button type="button" class="btn-crop-cancel" onclick="closeCropModal()">Cancel</button>
                <button type="button" class="btn-crop-confirm" onclick="confirmCrop()">Crop & Save</button>
            </div>
        </div>
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.2/cropper.min.js"></script>
<script src="/js/admin/productManagement.js"></script>